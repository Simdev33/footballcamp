generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String     @id @default(cuid())
  name      String
  email     String     @unique
  password  String
  role      String     @default("editor")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  news      News[]
  blogPosts BlogPost[]
}

model News {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  content   String
  imageUrl  String?
  published Boolean  @default(false)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GalleryImage {
  id        String   @id @default(cuid())
  url       String
  alt       String   @default("")
  category  String   @default("general")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

model Camp {
  id             String        @id @default(cuid())
  slug           String        @unique
  city           String
  venue          String
  dates          String
  price          String
  earlyBirdPrice String
  totalSpots     Int
  remainingSpots Int
  active         Boolean       @default(true)
  description    String        @default("")
  imageUrl       String?
  clubName       String        @default("SL Benfica")
  ageRange       String        @default("6-15")
  includes       String[]
  gallery        String[]
  videoUrl       String?
  mapEmbedUrl    String?
  schedule       Json?
  coaches        Json?
  faq            Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  applications   Application[]
}

model Application {
  id              String   @id @default(cuid())
  parentName      String
  parentEmail     String
  parentPhone     String
  childName       String
  childBirthDate  DateTime
  childCity       String   @default("")
  currentClub     String   @default("")
  jerseySize      String   @default("")
  shortsSize      String   @default("")
  socksSize       String   @default("")
  campId          String
  camp            Camp     @relation(fields: [campId], references: [id])
  status          String   @default("new")
  notes           String   @default("")
  siblingGroupId  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([siblingGroupId])
}

model BlogPost {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  excerpt   String   @default("")
  content   String
  imageUrl  String?
  category  String   @default("általános")
  published Boolean  @default(false)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteContent {
  id        String   @id @default(cuid())
  section   String
  locale    String   @default("hu")
  content   Json
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@unique([section, locale])
}
