generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String     @id @default(cuid())
  name      String
  email     String     @unique
  password  String
  role      String     @default("editor")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  news      News[]
  blogPosts BlogPost[]
}

model News {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  content   String
  imageUrl  String?
  published Boolean  @default(false)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GalleryImage {
  id        String   @id @default(cuid())
  url       String
  alt       String   @default("")
  category  String   @default("general")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

model Camp {
  id                String        @id @default(cuid())
  slug              String        @unique
  city              String
  venue             String
  dates             String
  startDate         DateTime?
  price             String        @default("")
  earlyBirdPrice    String        @default("")
  priceHuf          Int           @default(0)
  priceEur          Int           @default(0)
  earlyBirdPriceHuf Int           @default(0)
  earlyBirdPriceEur Int           @default(0)
  earlyBirdUntil    DateTime?
  depositPercent    Int           @default(0)
  totalSpots        Int
  remainingSpots    Int
  active            Boolean       @default(true)
  description       String        @default("")
  imageUrl          String?
  clubName          String        @default("SL Benfica")
  ageRange          String        @default("7-15")
  includes          String[]
  gallery           String[]
  videoUrl          String?
  mapEmbedUrl       String?
  schedule          Json?
  coaches           Json?
  faq               Json?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  applications      Application[]
}

model Application {
  id             String   @id @default(cuid())
  parentName     String
  parentEmail    String
  parentPhone    String
  // Billing address (optional — used for Számlázz.hu invoice generation)
  parentPostalCode String @default("")
  parentCity       String @default("")
  parentAddress    String @default("")
  parentTaxNumber  String @default("")
  childName      String
  childBirthDate DateTime
  childCity      String   @default("")
  currentClub    String   @default("")
  jerseySize     String   @default("")
  shortsSize     String   @default("")
  socksSize      String   @default("")
  campId         String
  camp           Camp     @relation(fields: [campId], references: [id])
  status         String   @default("new")
  notes          String   @default("")
  siblingGroupId String?

  // Payment tracking
  paymentStatus                 PaymentStatus  @default(PENDING)
  paymentMethod                 String         @default("CARD") // "CARD" | "TRANSFER"
  isInstallment                 Boolean        @default(false)
  currency                      String         @default("HUF")
  totalAmount                   Int            @default(0)
  depositAmount                 Int            @default(0)
  depositPaidAmount             Int            @default(0)
  remainderPaidAmount           Int            @default(0)
  // Bank transfer — shared across siblings of the same submission.
  transferReference             String?
  transferExpectedAmount        Int            @default(0)
  stripeCheckoutSessionId       String?
  stripePaymentIntentId         String?
  stripeCustomerId              String?
  stripeRemainderPaymentLinkId  String?
  stripeRemainderPaymentLinkUrl String?
  remainderReminderSentAt       DateTime?
  depositPaidAt                 DateTime?
  fullyPaidAt                   DateTime?
  paymentEvents                 PaymentEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([siblingGroupId])
  @@index([paymentStatus])
  @@index([stripeCheckoutSessionId])
  @@index([transferReference])
}

enum PaymentStatus {
  PENDING
  DEPOSIT_PAID
  FULLY_PAID
  FAILED
  EXPIRED
  REFUNDED
}

model PaymentEvent {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  type          String // "deposit_paid" | "remainder_paid" | "full_paid" | "failed" | "refund" | "link_sent"
  amount        Int         @default(0)
  currency      String      @default("HUF")
  stripeId      String? // session id / payment_intent / charge id
  // Számlázz.hu invoice reference (filled when an invoice was auto-generated)
  invoiceNumber String?
  invoiceUrl    String?
  note          String?
  createdAt     DateTime    @default(now())

  @@index([applicationId])
}

model BlogPost {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  excerpt   String   @default("")
  content   String
  imageUrl  String?
  category  String   @default("általános")
  published Boolean  @default(false)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteContent {
  id        String   @id @default(cuid())
  section   String
  locale    String   @default("hu")
  content   Json
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@unique([section, locale])
}

model NewsletterSubscriber {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String    @default("")
  locale         String    @default("hu")
  source         String    @default("footer")
  status         String    @default("active")
  consentText    String    @default("")
  unsubscribeToken String  @unique @default(cuid())
  subscribedAt   DateTime  @default(now())
  unsubscribedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deliveries      NewsletterDelivery[]

  @@index([status])
  @@index([subscribedAt])
}

model NewsletterTemplate {
  id          String   @id @default(cuid())
  slot        String   @unique
  label       String
  subject     String
  previewText String   @default("")
  body        String
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deliveries  NewsletterDelivery[]
}

model NewsletterDelivery {
  id           String               @id @default(cuid())
  subscriberId String
  subscriber   NewsletterSubscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  templateId   String
  template     NewsletterTemplate   @relation(fields: [templateId], references: [id], onDelete: Cascade)
  slot         String
  sentDate     String
  email        String
  status       String               @default("pending")
  providerId   String?
  error        String?
  sentAt       DateTime?
  createdAt    DateTime             @default(now())

  @@unique([subscriberId, slot, sentDate])
  @@index([status])
  @@index([sentDate])
}
